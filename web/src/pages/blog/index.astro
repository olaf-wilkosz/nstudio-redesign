---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Container from '../../components/Container.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getPostyBloga, getUstawienia, strapiMediaUrl } from '../../lib/strapi';

const posty = await getPostyBloga();
const ustawienia = await getUstawienia();

const formatData = (iso: string) =>
  new Date(iso).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout title="Blog" description="Blog Nstudio - wskazówki i inspiracje z zakresu projektowania wnętrz.">
  <Header />

  <PageHeader eyebrow="Blog" title="Inspiracje i wskazówki" />

  <section data-theme="light" class="bg-white py-20">
    <Container>
      {
        posty.length === 0 ? (
          <p class="text-muted">Wkrótce pojawią się tu pierwsze wpisy.</p>
        ) : (
          <div class="grid gap-12 md:grid-cols-2">
            {posty.map((post) => (
              <a href={`/blog/${post.slug}/`} class="group block">
                {post.okladka && (
                  <div class="aspect-[3/2] overflow-hidden bg-ink/5">
                    <img
                      src={strapiMediaUrl(post.okladka.url)}
                      alt={post.okladka.alternativeText ?? post.tytul}
                      loading="lazy"
                      class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                    />
                  </div>
                )}
                <p class="mt-4 text-xs tracking-[0.1em] text-muted uppercase">
                  {formatData(post.data)}
                </p>
                <h2 class="mt-2 font-serif text-2xl text-ink">{post.tytul}</h2>
                {post.zajawka && <p class="mt-2 text-sm text-muted">{post.zajawka}</p>}
              </a>
            ))}
          </div>
        )
      }
    </Container>
  </section>

  <Footer ustawienia={ustawienia} />
</Layout>
