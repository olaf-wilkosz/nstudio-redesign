---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import RealizacjeCarousel from '../components/RealizacjeCarousel.astro';
import Hero3DPlaceholder from '../components/Hero3DPlaceholder.astro';
import { getRealizacje, getUstawienia } from '../lib/strapi';
import { withBase } from '../lib/url';

const realizacje = await getRealizacje();
const ustawienia = await getUstawienia();
// The carousel needs a healthy surplus of slides over slidesPerView (up to
// 4.2 on wide screens) for Swiper's loop mode to work reliably - too few
// slides relative to slidesPerView makes loop silently disable itself
// (see Swiper's "not enough slides for loop mode" warning). Using the full
// portfolio here comfortably clears that bar.
const featured = realizacje;

const oferta = [
  {
    tytul: 'Projekt kompleksowy',
    opis: 'Pełny projekt wnętrza od podstaw - rzuty, wizualizacje i dokumentacja techniczna.',
  },
  {
    tytul: 'Projekt z nadzorem',
    opis: 'Projekt kompleksowy plus wsparcie i weryfikacja jakości na etapie realizacji.',
  },
  {
    tytul: 'Pakiet Pod Klucz',
    opis: 'Pełna koordynacja wykonawców i realizacja wykończeniowa - od projektu po klucze.',
  },
];
---

<Layout
  title="Strona główna"
  description="Nstudio - pracownia projektowania wnętrz Natalii Osipy-Indyckiej w Rzeszowie. Projekty mieszkań, domów i przestrzeni komercyjnych, realizacje pod klucz."
>
  <Header initialTheme="dark" />

  <!--
    HERO - tło to wyspa Astro (Hero3DPlaceholder.astro, client:visible) z
    lekkim shaderem WebGL. Statyczny gradient poniżej zostaje jako baza pod
    canvasem (fallback, gdyby WebGL się nie załadował, i żeby uniknąć błysku
    czystej czerni przed hydratacją wyspy). Docelowy punkt rozbudowy do pełnej
    sceny 3D (Three.js) - patrz komentarz w Hero3DPlaceholder.astro.
  -->
  <section data-theme="dark" class="relative flex min-h-screen items-end overflow-hidden bg-ink">
    <div
      class="absolute inset-0"
      style="background: radial-gradient(circle at 30% 20%, #3a2f22 0%, #1d1d1d 55%), linear-gradient(160deg, #2b2116 0%, #1d1d1d 70%);"
    >
    </div>
    <Hero3DPlaceholder />
    <Container class="relative z-10 pb-24 pt-40">
      <p class="mb-5 text-xs tracking-[0.25em] text-primary uppercase">
        Pracownia projektowania wnętrz · Rzeszów
      </p>
      <h1 class="max-w-2xl font-serif text-5xl leading-tight text-cream md:text-6xl">
        Wnętrza, które odzwierciedlają Ciebie.
      </h1>
      <p class="mt-6 max-w-xl text-cream/70">
        Natalia Osipa-Indycka projektuje przestrzenie łączące estetykę, funkcjonalność i osobisty
        charakter - od koncepcji po ostatni detal wykończenia.
      </p>
      <div class="mt-9 flex flex-wrap gap-4">
        <Button href={withBase('/portfolio/')} variant="primary">Zobacz realizacje</Button>
        <Button href={withBase('/kontakt/')} variant="outline-light">Umów konsultację</Button>
      </div>
    </Container>
  </section>

  <!-- Filozofia -->
  <section data-theme="light" class="py-24">
    <Container class="max-w-3xl text-center">
      <p class="font-serif text-3xl leading-snug text-ink md:text-4xl">
        „Wierzę, że wnętrze jest odzwierciedleniem duszy mieszkańców.”
      </p>
      <p class="mt-6 text-sm tracking-[0.1em] text-muted uppercase">
        Natalia Osipa-Indycka, założycielka Nstudio
      </p>
      <a href={withBase('/o-mnie/')} class="mt-4 inline-block text-sm text-ink underline underline-offset-4 hover:text-primary-dark">
        Poznaj mnie →
      </a>
    </Container>
  </section>

  <!-- Wybrane realizacje -->
  <section data-theme="light" class="overflow-hidden bg-white py-24">
    <Container class="mb-2">
      <div class="flex items-end justify-between">
        <h2 class="font-serif text-3xl text-ink md:text-4xl">Wybrane realizacje</h2>
        <a href={withBase('/portfolio/')} class="hidden text-sm text-muted hover:text-ink md:block">
          Całe portfolio →
        </a>
      </div>
    </Container>
    <RealizacjeCarousel realizacje={featured} />
  </section>

  <!-- Oferta -->
  <section data-theme="light" class="py-24">
    <Container>
      <h2 class="mb-12 font-serif text-3xl text-ink md:text-4xl">Jak pracujemy</h2>
      <div class="grid gap-10 md:grid-cols-3">
        {
          oferta.map((pakiet, i) => (
            <div class="border-t border-ink/15 pt-6">
              <span class="font-serif text-sm text-primary-dark">0{i + 1}</span>
              <h3 class="mt-2 font-serif text-xl text-ink">{pakiet.tytul}</h3>
              <p class="mt-3 text-sm text-muted">{pakiet.opis}</p>
            </div>
          ))
        }
      </div>
      <Button href={withBase('/oferta/')} variant="outline-dark" class="mt-12">Zobacz pełną ofertę</Button>
    </Container>
  </section>

  <Footer ustawienia={ustawienia} />
</Layout>
