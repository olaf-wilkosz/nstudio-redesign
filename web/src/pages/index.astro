---
import { getRealizacje, getPostyBloga, getUstawienia } from '../lib/strapi';

// Temporary wiring check for step 2 (Astro <-> Strapi SSG fetch) - the real
// homepage design lands in step 3/4.
const realizacje = await getRealizacje();
const postyBloga = await getPostyBloga();
const ustawienia = await getUstawienia();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Nstudio - setup w toku</title>
	</head>
	<body>
		<h1>Nstudio redesign - Astro + Strapi wiring OK</h1>
		<p>Realizacje z CMS: {realizacje.length}</p>
		<p>Posty bloga z CMS: {postyBloga.length}</p>
		<p>Telefon z Ustawien: {ustawienia.telefon ?? '(brak wpisu w CMS jeszcze)'}</p>
	</body>
</html>

