---
import '../styles/global.css';
import StructuredData from '../components/StructuredData.astro';
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description?: string;
  /** Root-relative path to a social preview image, e.g. from a Realizacja's cover photo. Falls back to a sitewide default. */
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Nstudio - pracownia projektowania wnętrz Natalii Osipy-Indyckiej. Rzeszów.',
  ogImage = '/images/og-default.jpg',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(withBase(ogImage), Astro.site);
const pageTitle = `${title} · Nstudio`;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Nstudio" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <StructuredData />

    <!--
      Fonts load asynchronously (preload + media=print swapped to "all" on
      load) instead of a plain blocking <link rel="stylesheet"> - the
      synchronous version cost ~800ms of render-blocking time in Lighthouse
      (two extra origins: fonts.googleapis.com for the CSS, then
      fonts.gstatic.com for the actual font files). font-display=swap in the
      URL means text still renders immediately in a fallback font either way.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700&family=Playfair+Display:wght@500;600;700&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700&family=Playfair+Display:wght@500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700&family=Playfair+Display:wght@500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body>
    <slot />
  </body>
</html>
