---
import '../styles/global.css';
import StructuredData from '../components/StructuredData.astro';
import Fonts from '../components/Fonts.astro';
import { withBase } from '../lib/url';

interface Props {
  title: string;
  description?: string;
  /** Root-relative path to a social preview image, e.g. from a Realizacja's cover photo. Falls back to a sitewide default. */
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Nstudio - pracownia projektowania wnętrz Natalii Osipy-Indyckiej. Rzeszów.',
  ogImage = '/images/og-default.jpg',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(withBase(ogImage), Astro.site);
const pageTitle = `${title} · Nstudio`;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!--
      Osobne <link media="(prefers-color-scheme)"> na dwa PNG (proba nr 1)
      nie dzialaly niezawodnie - przegladarki nie zawsze honoruja media na
      linkach favicon do przelaczania. Ten sam trik co w domyslnym
      placeholderze Astro dziala pewnie: JEDEN plik SVG z wbudowanym
      @media (prefers-color-scheme) w <style> wewnatrz samego SVG - to
      przegladarka renderujaca SVG ocenia bezposrednio, nie logika wyboru
      zasobu <link>.
    -->
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <link rel="icon" href={withBase('/favicon.ico')} sizes="any" />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Nstudio" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <StructuredData />

    <Fonts />
  </head>
  <body>
    <slot />
  </body>
</html>
