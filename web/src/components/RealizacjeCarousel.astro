---
import type { Realizacja } from '../lib/strapi';
import { strapiMediaUrl } from '../lib/strapi';

interface Props {
  realizacje: Realizacja[];
}

const { realizacje } = Astro.props;

const kategoriaLabel: Record<string, string> = {
  mieszkanie: 'Mieszkanie',
  dom: 'Dom',
  komercyjne: 'Komercyjne',
};
---

<div class="realizacje-swiper swiper">
  <div class="swiper-wrapper">
    {
      realizacje.map((r) => (
        <div class="swiper-slide">
          <a href={`/portfolio/${r.slug}/`} class="carousel-card">
            <div class="carousel-card-image">
              {r.okladka && (
                <img
                  src={strapiMediaUrl(r.okladka.url)}
                  alt={r.okladka.alternativeText ?? `Realizacja Nstudio - ${r.tytul}`}
                  loading="lazy"
                />
              )}
              <span class="carousel-badge">{kategoriaLabel[r.kategoria]}</span>
            </div>
            <p class="carousel-title">{r.tytul}</p>
            {r.lokalizacja && <p class="carousel-location">{r.lokalizacja}</p>}
          </a>
        </div>
      ))
    }
  </div>
  <button class="carousel-nav prev" aria-label="Poprzednia realizacja">‹</button>
  <button class="carousel-nav next" aria-label="Następna realizacja">›</button>
</div>

<style>
  .realizacje-swiper {
    padding: 2.5rem 0 3rem;
  }

  .swiper-slide {
    width: clamp(230px, 26vw, 340px);
  }

  .carousel-card {
    display: block;
  }

  .carousel-card-image {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: rgba(29, 29, 29, 0.05);
  }

  .carousel-card-image img {
    height: 100%;
    width: 100%;
    object-fit: cover;
  }

  .carousel-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: rgba(245, 241, 236, 0.9);
    color: var(--color-ink);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
  }

  .carousel-title {
    margin-top: 0.9rem;
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--color-ink);
  }

  .carousel-location {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .carousel-nav {
    position: absolute;
    top: 42%;
    z-index: 10;
    display: flex;
    height: 3rem;
    width: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: rgba(245, 241, 236, 0.9);
    color: var(--color-ink);
    font-size: 1.5rem;
    line-height: 1;
    box-shadow: 0 8px 24px rgba(29, 29, 29, 0.12);
    transition:
      opacity 0.3s ease,
      transform 0.2s ease;
  }

  .carousel-nav:hover {
    transform: translateY(-50%) scale(1.06);
  }

  .carousel-nav.prev {
    left: 0.5rem;
  }

  .carousel-nav.next {
    right: 0.5rem;
  }

  @media (min-width: 768px) {
    .carousel-nav.prev {
      left: 2rem;
    }
    .carousel-nav.next {
      right: 2rem;
    }
  }
</style>

<script>
  import { Swiper } from 'swiper';
  import { EffectCoverflow, Autoplay, Navigation } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-coverflow';

  document.querySelectorAll<HTMLElement>('.realizacje-swiper').forEach((el) => {
    const container = el.parentElement!;
    const swiper = new Swiper(el, {
      modules: [EffectCoverflow, Autoplay, Navigation],
      effect: 'coverflow',
      centeredSlides: true,
      slidesPerView: 'auto',
      loop: true,
      speed: 600,
      grabCursor: true,
      coverflowEffect: {
        rotate: 0,
        stretch: 0,
        depth: 220,
        modifier: 1.3,
        slideShadows: false,
      },
      autoplay: {
        delay: 3200,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      navigation: {
        nextEl: container.querySelector('.carousel-nav.next'),
        prevEl: container.querySelector('.carousel-nav.prev'),
      },
      on: {
        progress(swiper) {
          swiper.slides.forEach((slideEl) => {
            const p = Math.min(Math.abs((slideEl as unknown as { progress: number }).progress), 1);
            (slideEl as HTMLElement).style.opacity = String(1 - p * 0.6);
          });
        },
      },
    });
  });
</script>
