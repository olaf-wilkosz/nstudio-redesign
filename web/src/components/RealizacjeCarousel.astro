---
import type { Realizacja } from '../lib/strapi';
import { strapiImageSrc } from '../lib/strapi';
import { withBase } from '../lib/url';

interface Props {
  realizacje: Realizacja[];
}

const { realizacje } = Astro.props;

const kategoriaLabel: Record<string, string> = {
  mieszkanie: 'Mieszkanie',
  dom: 'Dom',
  komercyjne: 'Komercyjne',
};
---

<div class="carousel-wrap">
  <div class="realizacje-swiper swiper">
    <div class="swiper-wrapper">
      {
        realizacje.map((r) => (
          <div class="swiper-slide">
            <a href={withBase(`/portfolio/${r.slug}/`)} class="carousel-card">
              <div class="carousel-card-image">
                {r.okladka && (
                  <img
                    src={strapiImageSrc(r.okladka, 'medium')}
                    alt={r.okladka.alternativeText ?? `Realizacja Nstudio - ${r.tytul}`}
                  />
                )}
                <span class="carousel-badge">{kategoriaLabel[r.kategoria]}</span>
              </div>
              <p class="carousel-title">{r.tytul}</p>
              {r.lokalizacja && <p class="carousel-location">{r.lokalizacja}</p>}
            </a>
          </div>
        ))
      }
    </div>
  </div>
  <div class="carousel-nav-frame">
    <button class="carousel-nav prev" aria-label="Poprzednia realizacja">‹</button>
    <button class="carousel-nav next" aria-label="Następna realizacja">›</button>
  </div>
</div>

<style>
  .carousel-wrap {
    position: relative;
  }

  .realizacje-swiper {
    padding: 2.5rem 0 3rem;
  }

  /* Base look before JS applies the progressive per-slide falloff (below). */
  .swiper-slide {
    opacity: 0.4;
    filter: grayscale(0.9);
    transition:
      opacity 0.35s ease,
      filter 0.35s ease;
  }

  .swiper-slide:hover {
    opacity: 1 !important;
    filter: grayscale(0) !important;
  }

  .carousel-card {
    display: block;
  }

  .carousel-card-image {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: rgba(29, 29, 29, 0.05);
  }

  .carousel-card-image img {
    height: 100%;
    width: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .swiper-slide:hover .carousel-card-image img {
    transform: scale(1.06);
  }

  .carousel-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: rgba(245, 241, 236, 0.9);
    color: var(--color-ink);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
  }

  .carousel-title {
    margin-top: 0.9rem;
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--color-ink);
  }

  .carousel-location {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  /* Bounds nav arrows to the page's content width (matches Container's
     max-w-6xl) instead of the full-bleed carousel track, so on ultrawide
     monitors they sit near the visible content instead of far off at the
     viewport edges. */
  .carousel-nav-frame {
    position: absolute;
    inset: 0;
    max-width: 72rem;
    margin-inline: auto;
    pointer-events: none;
  }

  .carousel-nav {
    position: absolute;
    top: 42%;
    z-index: 10;
    display: flex;
    height: 3.25rem;
    width: 3.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: rgba(245, 241, 236, 0.95);
    color: var(--color-ink);
    font-size: 1.6rem;
    line-height: 1;
    box-shadow: 0 8px 24px rgba(29, 29, 29, 0.15);
    pointer-events: auto;
    transition:
      opacity 0.3s ease,
      transform 0.2s ease;
  }

  .carousel-nav:hover {
    transform: scale(1.08);
  }

  .carousel-nav.prev {
    left: -0.5rem;
  }

  .carousel-nav.next {
    right: -0.5rem;
  }

  @media (min-width: 768px) {
    .carousel-nav.prev {
      left: -1.5rem;
    }
    .carousel-nav.next {
      right: -1.5rem;
    }
  }
</style>

<script>
  import { Swiper } from 'swiper';
  import { EffectCoverflow, Autoplay, Navigation } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-coverflow';

  document.querySelectorAll<HTMLElement>('.realizacje-swiper').forEach((el) => {
    const wrap = el.closest('.carousel-wrap')!;
    const swiper = new Swiper(el, {
      modules: [EffectCoverflow, Autoplay, Navigation],
      effect: 'coverflow',
      centeredSlides: true,
      // Fixed slide counts per breakpoint instead of slidesPerView: 'auto' -
      // 'auto' + loop is a known-fragile Swiper combination (loop can run out
      // of pre-rendered slides and appear to dead-end at the last real slide).
      slidesPerView: 1.3,
      breakpoints: {
        640: { slidesPerView: 2.2 },
        1024: { slidesPerView: 3.4 },
        1400: { slidesPerView: 4.2 },
      },
      spaceBetween: 48,
      loop: true,
      loopAdditionalSlides: 8,
      speed: 600,
      grabCursor: true,
      coverflowEffect: {
        rotate: 0,
        stretch: 30,
        depth: 100,
        modifier: 1,
        slideShadows: false,
      },
      autoplay: {
        delay: 3200,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      navigation: {
        nextEl: wrap.querySelector('.carousel-nav.next'),
        prevEl: wrap.querySelector('.carousel-nav.prev'),
      },
      on: {
        progress(sw) {
          sw.slides.forEach((slideEl) => {
            const p = Math.min(Math.abs((slideEl as unknown as { progress: number }).progress), 3);
            const falloff = Math.min(p / 2, 1);
            (slideEl as HTMLElement).style.opacity = String(1 - falloff * 0.75);
            (slideEl as HTMLElement).style.filter = `grayscale(${falloff * 0.9})`;
          });
        },
      },
    });
  });
</script>
