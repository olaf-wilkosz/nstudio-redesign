---
import type { Realizacja } from '../lib/strapi';
import { strapiMediaUrl } from '../lib/strapi';

interface Props {
  realizacja: Realizacja;
  /** Controls the card's aspect ratio - 'auto' keeps the image's natural ratio (used for masonry layouts). */
  aspect?: 'square' | 'portrait' | 'landscape' | 'auto';
}

const { realizacja, aspect = 'square' } = Astro.props;

const aspectClass = {
  square: 'aspect-[4/5]',
  portrait: 'aspect-[3/4]',
  landscape: 'aspect-[4/3]',
  auto: '',
}[aspect];

const kategoriaLabel: Record<string, string> = {
  mieszkanie: 'Mieszkanie',
  dom: 'Dom',
  komercyjne: 'Komercyjne',
};
---

<a
  href={`/portfolio/${realizacja.slug}/`}
  class="group mb-8 block break-inside-avoid"
  data-kategoria={realizacja.kategoria}
>
  <div class={`relative overflow-hidden bg-ink/5 ${aspectClass}`}>
    {
      realizacja.okladka && (
        <img
          src={strapiMediaUrl(realizacja.okladka.url)}
          alt={realizacja.okladka.alternativeText ?? `Realizacja Nstudio - ${realizacja.tytul}`}
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
        />
      )
    }
    <span class="absolute top-4 left-4 bg-cream/90 px-3 py-1 text-[10px] tracking-[0.12em] text-ink uppercase">
      {kategoriaLabel[realizacja.kategoria]}
    </span>
  </div>
  <p class="mt-3 font-serif text-lg text-ink">{realizacja.tytul}</p>
  {realizacja.lokalizacja && <p class="text-xs text-muted">{realizacja.lokalizacja}</p>}
</a>
