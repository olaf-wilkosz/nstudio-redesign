---
interface Props {
  /** Theme of the first section on the page, so the header renders correctly server-side before scroll JS runs (no flash). */
  initialTheme?: 'dark' | 'light';
}

const { initialTheme = 'light' } = Astro.props;

const NAV = [
  { href: '/', label: 'Strona główna' },
  { href: '/o-mnie/', label: 'O mnie' },
  { href: '/portfolio/', label: 'Portfolio' },
  { href: '/oferta/', label: 'Oferta' },
  { href: '/blog/', label: 'Blog' },
  { href: '/kontakt/', label: 'Kontakt' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class:list={['at-top', initialTheme === 'dark' ? 'theme-dark' : 'theme-light']}
>
  <div class="header-inner">
    <a href="/" class="logo-wrap" aria-label="Nstudio - strona główna">
      <img src="/logo/nstudio-logo-white.png" alt="" class="logo-white" />
      <img src="/logo/nstudio-logo-black.png" alt="Nstudio" class="logo-black" />
    </a>
    <nav class="hidden gap-8 md:flex">
      {
        NAV.map((item) => (
          <a href={item.href} class:list={['nav-link', { active: currentPath === item.href }]}>
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  #site-header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 50;
  }

  .header-inner {
    margin-inline: auto;
    margin-top: 0.75rem;
    max-width: calc(72rem - 1.5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 1.5rem;
    border-radius: 9999px;
    backdrop-filter: blur(14px);
    transition:
      margin 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      padding 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      max-width 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      border-radius 0.4s ease,
      background-color 0.4s ease,
      box-shadow 0.4s ease;
  }

  /* Flush full-width bar right at the top of the page; detaches into a floating pill on first scroll. */
  #site-header.at-top .header-inner {
    margin-top: 0;
    max-width: 72rem;
    padding: 1.5rem 1.5rem;
    border-radius: 0;
  }

  #site-header.theme-dark .header-inner {
    background-color: rgba(29, 29, 29, 0.55);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.18);
  }

  #site-header.theme-light .header-inner {
    background-color: rgba(245, 241, 236, 0.8);
    box-shadow: 0 10px 40px rgba(29, 29, 29, 0.08);
  }

  .logo-wrap {
    position: relative;
    display: block;
    height: 3rem;
    width: 3rem;
    flex-shrink: 0;
  }

  .logo-wrap img {
    position: absolute;
    inset: 0;
    height: 100%;
    width: 100%;
    object-fit: contain;
    transition: opacity 0.4s ease;
  }

  .logo-white {
    opacity: 1;
  }

  .logo-black {
    opacity: 0;
  }

  #site-header.theme-light .logo-white {
    opacity: 0;
  }

  #site-header.theme-light .logo-black {
    opacity: 1;
  }

  .nav-link {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(245, 241, 236, 0.8);
    transition: color 0.4s ease;
  }

  .nav-link:hover {
    color: rgba(245, 241, 236, 1);
  }

  .nav-link.active {
    color: rgb(245, 241, 236);
    font-weight: 500;
  }

  #site-header.theme-light .nav-link {
    color: rgba(29, 29, 29, 0.65);
  }

  #site-header.theme-light .nav-link:hover {
    color: rgba(29, 29, 29, 1);
  }

  #site-header.theme-light .nav-link.active {
    color: rgb(29, 29, 29);
  }
</style>

<script>
  function setupHeader() {
    const header = document.getElementById('site-header');
    if (!header) return;

    const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-theme]'));
    if (sections.length === 0) return;

    // Sample point just below the header's vertical center - whichever section
    // currently sits behind it decides the header's light/dark theme.
    const PROBE_Y = 48;

    function update() {
      header!.classList.toggle('at-top', window.scrollY < 8);

      for (const section of sections) {
        const rect = section.getBoundingClientRect();
        if (rect.top <= PROBE_Y && rect.bottom > PROBE_Y) {
          const isDark = section.dataset.theme === 'dark';
          header!.classList.toggle('theme-dark', isDark);
          header!.classList.toggle('theme-light', !isDark);
          break;
        }
      }
    }

    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            update();
            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true }
    );

    update();
  }

  setupHeader();
</script>
